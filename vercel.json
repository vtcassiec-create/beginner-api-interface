{
  "framework": null,
  "functions": {
    "api/chat.py": { "maxDuration": 60 },
    "api/backup.py": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/(app.js|drawer.js|drawer.html|index.html|sw.js|manifest.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/surprise", "schedule": "0 20 * * *" },
    { "path": "/api/backup", "schedule": "0 8 * * *" }
  ]
}
